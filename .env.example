# =============================================================================
# Zelance — Environment Variables
# Copy to .env.local for local dev. Set all required vars in Vercel/production.
# =============================================================================

# --- Supabase (required) ---
# Project URL from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# Anon/public key — safe for browser; RLS enforces access
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY; bypasses RLS. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# --- App URL (required in production) ---
# Canonical origin for email links and redirects (e.g. https://zelance.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Razorpay payments (required for checkout) ---
# Dashboard → Settings → API Keys → Key ID (live key in production)
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Dashboard → Settings → API Keys → Key Secret (server only)
RAZORPAY_KEY_SECRET=
# Dashboard → Webhooks → secret for HMAC signature verification (server only)
# Webhook URL: https://YOUR_DOMAIN/api/webhooks/razorpay
# Events: payment.captured, order.paid
RAZORPAY_WEBHOOK_SECRET=

# --- Email — Resend (required for transactional email) ---
# https://resend.com/api-keys
RESEND_API_KEY=
# Verified sender domain (e.g. Zelance <notifications@yourdomain.com>)
# Falls back to onboarding@resend.dev (dev/sandbox only) if unset
RESEND_FROM_EMAIL=

# --- Google Gemini AI (required for AI features) ---
# Used by chat, search-intent, estimates, embeddings
GEMINI_API_KEY=
# Optional override for /api/embed (default: text-embedding-004)
GEMINI_EMBEDDING_MODEL=

# --- PostHog analytics (recommended) ---
NEXT_PUBLIC_POSTHOG_KEY=
# Optional; defaults to https://app.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Admin alerts (required if using /api/admin/alerts) ---
# Bearer token for POST /api/admin/alerts (server only)
ADMIN_SECRET=
